{
  "expo": {
    "name": "Qaaf",
    "slug": "qaaf",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./src/assets/play-store/ic_launcher-playstore.png",
    "scheme": "qaaf",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.shahid.qaaf"
    },
    "android": {
      "package": "com.shahid.qaaf",
      "adaptiveIcon": {
        "foregroundImage": "./src/assets/res/mipmap-xxxhdpi/ic_launcher_foreground.png",
        "backgroundImage": "./src/assets/res/mipmap-xxxhdpi/ic_launcher_background.png",
        "monochromeImage": "./src/assets/res/drawable/ic_launcher_monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./src/assets/play-store/ic_launcher-playstore.png"
    },
    "plugins": [
      [
        "expo-splash-screen",
        {
          "image": "./src/assets/play-store/ic_launcher-playstore.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "image": "./src/assets/play-store/ic_launcher-playstore.png",
            "imageWidth": 200,
            "backgroundColor": "#0F0F14"
          }
        }
      ],
      "expo-video",
      "expo-camera",
      "expo-image-picker",
      [
        "expo-media-library",
        {
          "photosPermission": "Allow Qaaf to access your photos to upload stories and posts.",
          "savePhotosPermission": "Allow Qaaf to save photos.",
          "isAccessMediaLocationEnabled": true
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "db99c597-fd36-4753-ad7a-3e2e40c814a0"
      }
    }
  }
}